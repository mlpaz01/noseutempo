# ── Banco de dados ───────────────────────────────────────────────────────────
# mysql://usuario:senha@localhost:3306/nomeutempo_marketing
DATABASE_URL=mysql://root:SENHA@localhost:3306/nomeutempo_marketing

# ── Autenticação JWT ─────────────────────────────────────────────────────────
# Gere com: openssl rand -hex 64
JWT_SECRET=troque_por_uma_chave_secreta_longa_e_aleatoria

# ── App ───────────────────────────────────────────────────────────────────────
VITE_APP_ID=marketing-engine
PORT=3010
NODE_ENV=production

# ── OpenRouter (IA de Recalibração) ───────────────────────────────────────────
# Obtenha em: https://openrouter.ai
OPENROUTER_API_KEY=sk-or-...

# ── AWS S3 (armazenamento de imagens) ─────────────────────────────────────────
# Opcional — se não configurado, imagens são referenciadas por URL direta
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
